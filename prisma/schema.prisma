generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Player {
  id                          String   @id @default(cuid())
  nick                        String   @unique
  mmr                         Int
  stake                       Float
  mainRole                    Int
  flexRole                    Int?
  wallet                      String?
  nightMatches                Int      @default(0)
  matchesPlayed               Int      @default(0)
  telegramId                  String?
  discordId                   String?  @unique
  isActiveInDatabase          Boolean  @default(true)
  isDisqualified              Boolean  @default(false)
  /// Сколько раз игрок был импортирован как участник турнира
  adminParticipationCount     Int      @default(0)
  /// Играл ли до последнего импорта
  hasPlayedBefore             Boolean  @default(false)
  /// Название последнего турнира, с которого был импортирован
  lastImportedTournamentName  String?
  /// Когда последний раз синхронизировался с админкой
  lastSyncedAt                DateTime?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  poolEntries          SubstitutionPoolEntry[]
  substitutedInLogs    MatchSubstitutionLog[]  @relation("SubstitutedPlayer")
  substitutionInLogs   MatchSubstitutionLog[]  @relation("SubstitutionPlayer")
  waveCandidates       WaveCandidate[]
  waveResponses        WaveResponse[]
  tournamentParticipations PlayerTournamentParticipation[]
}

model Team {
  id        String   @id @default(cuid())
  name      String   @unique
  player1Id String?
  player2Id String?
  player3Id String?
  player4Id String?
  player5Id String?
  captainId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  poolEntries SubstitutionPoolEntry[]
  logs        MatchSubstitutionLog[]
}

model SubstitutionPoolEntry {
  id                  String     @id @default(cuid())
  playerId            String
  status              String     @default("Active")
  joinTime            DateTime   @default(now())
  assignedTeamId      String?
  replacedPlayerId    String?
  pickedTime          DateTime?
  source              String
  adminQueuePosition  Int?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  player       Player  @relation(fields: [playerId], references: [id])
  assignedTeam Team?   @relation(fields: [assignedTeamId], references: [id])
  logs         MatchSubstitutionLog[]

  @@map("ReplacementPoolEntry")
}

model TournamentMatch {
  id           String    @id @default(cuid())
  round        Int
  slot         Int
  homeTeam     String
  awayTeam     String
  scheduledAt  DateTime
  endsAt       DateTime
  status       String    @default("Scheduled")
  techLossTeam String?
  notifiedAt   DateTime?
  judgeName    String?
  comment      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ── Tournament Import from Admin ──────────────────────────────────────────────

model AdminTournament {
  id              String   @id @default(cuid())
  /// ID турнира в системе источника
  externalId      String   @unique
  name            String
  status          String?
  startDate       DateTime?
  endDate         DateTime?
  participantCount Int     @default(0)
  lastSyncedAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  participations PlayerTournamentParticipation[]
  syncRuns       AdminTournamentSyncRun[]
}

model PlayerTournamentParticipation {
  id                String   @id @default(cuid())
  playerId          String
  tournamentId      String
  /// Сколько раз участвовал в этом турнире (по данным импорта)
  participationCount Int     @default(1)
  /// Участвовал ли до этого импорта
  playedBefore      Boolean  @default(false)
  /// Статус в очереди: Registered | Waiting | Confirmed | Disqualified и т.д.
  tournamentStatus  String?
  queuePosition     Int?
  qualifyRating     Float?
  bidSize           Float?
  balance           Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  player     Player           @relation(fields: [playerId], references: [id])
  tournament AdminTournament  @relation(fields: [tournamentId], references: [id])

  @@unique([playerId, tournamentId])
}

model AdminTournamentSyncRun {
  id           String   @id @default(cuid())
  tournamentId String
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
  status       String   @default("Running")
  created      Int      @default(0)
  updated      Int      @default(0)
  failed       Int      @default(0)
  total        Int      @default(0)
  errorLog     String?

  tournament AdminTournament @relation(fields: [tournamentId], references: [id])
}

// ── Discord Bot: Substitution Search ──────────────────────────────────────────

model SubstitutionSearchSession {
  id                  String   @id @default(cuid())
  teamId              String
  teamName            String
  neededRole          Int
  replacedPlayerId    String?
  replacedPlayerNick  String?
  replacedPlayerMmr   Int      @default(0)
  currentPlayerCount  Int      @default(5)
  currentTeamAvgMmr   Int
  targetAvgMmr        Int
  maxDeviation        Int      @default(800)
  /// Active | Completed | Exhausted | Cancelled
  status              String   @default("Active")
  /// Discord user ID or judge name who triggered the search
  triggeredBy         String
  guildId             String
  channelId           String
  currentWave         Int      @default(0)
  selectedPlayerId    String?
  selectedPoolEntryId String?
  /// Number of substitution slots needed (multi-sub support)
  slotsNeeded         Int      @default(1)
  /// Active match ID from admin site (optional, for display in bot message)
  activeMatchId       String?
  /// Away team ID (set when this is a unified match session covering both teams)
  awayTeamId          String?
  /// Away team name
  awayTeamName        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  waves SubstitutionWave[]
  slots SubstitutionSlot[]

  @@map("ReplacementSearchSession")
}

model SubstitutionSlot {
  id                  String    @id @default(cuid())
  sessionId           String
  slotIndex           Int
  replacedPlayerId    String?
  replacedPlayerNick  String?
  neededRole          Int
  teamSlot            Int
  /// Which team this slot belongs to (for unified match sessions)
  slotTeamId          String?
  slotTeamName        String?
  assignedPlayerId    String?
  assignedPoolEntryId String?
  assignedAt          DateTime?
  createdAt           DateTime  @default(now())

  session SubstitutionSearchSession @relation(fields: [sessionId], references: [id])
}

model SubstitutionWave {
  id         String   @id @default(cuid())
  sessionId  String
  waveNumber Int
  /// Active | Processing | Completed | NoResponse
  status     String   @default("Active")
  /// Discord message ID posted in the channel
  messageId  String?
  channelId  String
  startsAt   DateTime @default(now())
  endsAt     DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  session    SubstitutionSearchSession @relation(fields: [sessionId], references: [id])
  candidates WaveCandidate[]
  responses  WaveResponse[]

  @@map("ReplacementWave")
}

model WaveCandidate {
  id            String  @id @default(cuid())
  waveId        String
  playerId      String
  poolEntryId   String
  /// Snapshot of player.discordId at wave creation time (for mentions)
  discordId     String?
  /// Position in the reserve queue (0-based) when this wave was created
  queuePosition Int
  createdAt     DateTime @default(now())

  wave   SubstitutionWave @relation(fields: [waveId], references: [id])
  player Player           @relation(fields: [playerId], references: [id])
}

model WaveResponse {
  id        String   @id @default(cuid())
  waveId    String
  playerId  String
  discordId String
  clickedAt DateTime @default(now())
  subScore  Float?
  selected  Boolean  @default(false)

  wave   SubstitutionWave @relation(fields: [waveId], references: [id])
  player Player           @relation(fields: [playerId], references: [id])

  @@unique([waveId, playerId])
}

// ──────────────────────────────────────────────────────────────────────────────

model MatchSubstitutionLog {
  id                    String   @id @default(cuid())
  timestamp             DateTime @default(now())
  actionType            String
  matchId               String?
  teamId                String?
  teamName              String?
  neededRole            Int?
  replacedPlayerId      String?
  replacedPlayerNick    String?
  replacedPlayerMmr     Int?
  replacementPlayerId   String?
  replacementPlayerNick String?
  replacementPlayerMmr  Int?
  judgeName             String?
  comment               String?
  resultStatus          String
  poolEntryId           String?
  createdAt             DateTime @default(now())

  team              Team?                  @relation(fields: [teamId], references: [id])
  substitutedPlayer Player?               @relation("SubstitutedPlayer", fields: [replacedPlayerId], references: [id])
  substitutionPlayer Player?              @relation("SubstitutionPlayer", fields: [replacementPlayerId], references: [id])
  poolEntry         SubstitutionPoolEntry? @relation(fields: [poolEntryId], references: [id])

  @@map("MatchReplacementLog")
}
